# Copia este archivo a ImagesMangGenerator/.env y ajusta las rutas locales.

# Carpeta donde estan los cubos MaNGIA ya generados.
MANGIA_INPUT_DIR=/ruta/a/cubos_mangia

# Carpeta donde se escribiran NPZ, manifest y logs.
MANGIA_OUTPUT_DIR=/ruta/a/salida_images_mangia

# Patron de cubos a procesar. Para cubos oficiales MaNGIA suele ser:
MANGIA_PATTERN=*.cube.fits.gz

# Buscar tambien en subcarpetas: 1 si, 0 no.
MANGIA_RECURSIVE=0

# Cantidad de workers. Recomendado: numero de cores fisicos o un poco menos.
MANGIA_WORKERS=8

# Shape de salida. Usar native para no recortar cubos 69x69 o 74x74.
# Alternativas explicitas: 69,69 o 74,74.
MANGIA_OUTPUT_SHAPE=native

# Si ya existe el NPZ de una galaxia, saltarlo.
MANGIA_SKIP_EXISTING=1

# Limite opcional para pruebas. Vacio = catalogo completo.
MANGIA_LIMIT=

# Manifest opcional. Vacio = $MANGIA_OUTPUT_DIR/manifest.csv
MANGIA_MANIFEST=

# Previews PNG desde los NPZ generados.
# Si PREVIEW_INPUT_DIR queda vacio, usa MANGIA_OUTPUT_DIR.
PREVIEW_INPUT_DIR=
PREVIEW_OUTPUT_DIR=
PREVIEW_PATTERN=*.npz
PREVIEW_RECURSIVE=0
PREVIEW_OVERWRITE=0
PREVIEW_STRETCH=asinh
PREVIEW_PERCENTILE=99.5
PREVIEW_SMOOTH_SIGMA=0.85
PREVIEW_SIZE=768
PREVIEW_RGB_ORDER=irg

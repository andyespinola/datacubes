# Copia este archivo a .env y ajusta los paths segun la maquina destino.

PYTHON_BIN=python3
VENV_DIR=.venv

# Puedes dejar RSS_INPUT_DIR relativo al proyecto si vas a copiar ahi los RSS.
RSS_INPUT_DIR=./rss_input
OUTPUT_DIR=./output
LOG_DIR=./logs

CATALOG_PATH=./MaNGIA_catalog.fits
TEMPLATE_SSP_CONTROL=./official_mangia/libs/MaStar_CB19.slog_1_5.fits.gz
RSS_GLOB=*.cube_RSS.fits*

# Escalado batch. El pipeline actual usa CPU, no GPU.
BATCH_WORKERS=8
START_INDEX=0
COUNT=0
INCLUDE_GAS=0
FORCE_REBUILD=0

NOISE_SN=5.0
NOISE_RADIUS=2.0
THET=0.0

# Recomendado para evitar sobreasignacion al lanzar varios procesos en paralelo.
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1

VIEWER_HOST=0.0.0.0
VIEWER_PORT=8000

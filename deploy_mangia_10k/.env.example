# Copia este archivo a .env en la maquina destino y ajusta los paths reales.
# Este template asume:
# - el repo esta clonado en una carpeta local;
# - los 10000 RSS viven en otro disco o carpeta grande;
# - el catalogo y el template SSP pueden copiarse desde una ruta local
#   o descargarse desde una URL si la tienes.

PYTHON_BIN=python3
VENV_DIR=.venv

# Directorios principales.
# Ejemplo tipico:
# RSS_INPUT_DIR=/mnt/datos/mangia/rss_10000
# OUTPUT_DIR=/mnt/datos/mangia/cubos_reconstruidos
# LOG_DIR=/mnt/datos/mangia/logs_reconstruccion
RSS_INPUT_DIR=/ruta/a/rss_10000
OUTPUT_DIR=/ruta/a/cubos_reconstruidos
LOG_DIR=/ruta/a/logs_reconstruccion

CATALOG_PATH=./MaNGIA_catalog.fits
TEMPLATE_SSP_CONTROL=./official_mangia/libs/MaStar_CB19.slog_1_5.fits.gz
RSS_GLOB=*.cube_RSS.fits*

# Si el bootstrap no encuentra estos archivos ya presentes, intentara copiarlos
# desde estas rutas o descargarlos desde estas URLs.
CATALOG_SOURCE_PATH=/ruta/a/MaNGIA_catalog.fits
TEMPLATE_SOURCE_PATH=/ruta/a/MaStar_CB19.slog_1_5.fits.gz
CATALOG_URL=
TEMPLATE_URL=

# Opcional: carpeta padre donde el bootstrap intentara buscar assets ya existentes.
WORKSPACE_ROOT=

# Escalado batch. El pipeline actual usa CPU, no GPU.
BATCH_WORKERS=8
START_INDEX=0
COUNT=0
INCLUDE_GAS=0
FORCE_REBUILD=0

NOISE_SN=5.0
NOISE_RADIUS=2.0
THET=0.0

# Recomendado para evitar sobreasignacion al lanzar varios procesos en paralelo.
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1

# Viewer local para inspeccion.
VIEWER_HOST=0.0.0.0
VIEWER_PORT=8000
